# ------------------------------------------------------------------------------
# Backend-Konfiguration (share.alae.app). Auf dem QNAP als .env neben der
# docker-compose.yml ablegen. NICHT ins Git committen.
# ------------------------------------------------------------------------------

# Öffentliche Adresse des Frontends (Netlify) – wird für CORS gebraucht.
PUBLIC_APP_URL=https://share.alae.app
# Optional zusätzlich erlaubte Origins (kommagetrennt), z. B. die rohe Netlify-URL.
EXTRA_CORS_ORIGINS=

# Wo die Daten liegen. Im Container ist das /data (per Volume auf den QNAP-
# Freigabeordner "share" gemountet, siehe docker-compose.yml). Lokal leer lassen.
DATA_DIR=/data

# Secret zum Signieren der Zugriffs-Token. Mit `openssl rand -base64 48` erzeugen.
JWT_SECRET=

# Passwort, um neue Bereiche anzulegen/verwalten (Admin-Schlüssel).
ADMIN_KEY=

# Wie lange ein Bereichs-Zugang gültig bleibt (Tage).
ACCESS_TOKEN_TTL_DAYS=60

# Upload-Einstellungen.
UPLOAD_CHUNK_SIZE_BYTES=5242880   # 5 MB pro Chunk (klein genug für Cloudflare)
UPLOAD_MAX_FILE_MB=5120           # max. 5 GB pro Datei (Videos)
UPLOAD_SESSION_TTL_HOURS=48

# Bildvarianten.
IMG_THUMB_MAX=600
IMG_PREVIEW_MAX=1800
IMG_THUMB_QUALITY=72
IMG_PREVIEW_QUALITY=80

# Video (ffmpeg ist im Docker-Image enthalten).
VIDEO_PROCESSING=true
VIDEO_PREVIEW_MAX_HEIGHT=720
VIDEO_PREVIEW_CRF=26

# Cookies (nur relevant, falls der Token auch als Cookie genutzt wird).
COOKIE_SECURE=true
COOKIE_SAMESITE=lax
COOKIE_DOMAIN=.alae.app
