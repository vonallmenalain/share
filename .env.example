# ============================================================================
# Beispiel-.env für das QNAP (liegt NEBEN der docker-compose.yml).
# Kopiere diese Datei nach ".env" und trage deine Werte ein.
# Die ausführlichen Backend-Variablen sind in backend/.env.example beschrieben –
# du kannst alle davon hier ebenfalls setzen.
# ============================================================================

# --- Backend ---------------------------------------------------------------
PUBLIC_APP_URL=https://share.alae.app
EXTRA_CORS_ORIGINS=
JWT_SECRET=
ADMIN_KEY=
UPLOAD_MAX_FILE_MB=5120
COOKIE_SECURE=true
COOKIE_SAMESITE=lax
COOKIE_DOMAIN=.alae.app

# --- Optional: anderes Backend-Image verwenden -----------------------------
# BACKEND_IMAGE=ghcr.io/vonallmenalain/share-backend:latest

# --- Cloudflare Tunnel (nur mit --profile tunnel) --------------------------
CLOUDFLARE_TUNNEL_TOKEN=

# --- Watchtower (nur mit --profile autoupdate) -----------------------------
WATCHTOWER_POLL_INTERVAL=300
